// Modul Mail untuk Tenun — kirim (SMTP) + baca (IMAP) email.
// Fitur: teks, HTML, multipart/alternative, lampiran, validasi alamat,
// transkrip/log percakapan, IMAP (login/pilih/fetch/search/flags).
// Catatan: koneksi teks polos (tanpa TLS). Untuk server ber-TLS gunakan relay
// lokal / stunnel. Lihat README.

impor "./util.tenun";
impor "./mime.tenun";
impor "./smtp.tenun";
impor "./imap.tenun";
impor "./resend.tenun";
